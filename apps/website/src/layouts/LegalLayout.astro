---
// Layout for long-form legal markdown pages (privacy, terms, etc.).
// Drop a `.md` into src/pages/ with `layout: ../layouts/LegalLayout.astro`
// in its frontmatter and you get a fully styled page — no .astro plumbing
// to touch when editing prose.
//
// EN-only by design. Legal copy in a single authoritative language avoids
// translation-induced ambiguity; if a zh-hant version is ever added later,
// note explicitly which version controls.

import "../styles/global.css";
import SiteFooter from "../components/SiteFooter.astro";
import MarginMark from "../components/MarginMark.astro";

interface Frontmatter {
  title: string;
  effective: string;
  description?: string;
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const { title, effective, description } = frontmatter;
const pageTitle = `${title} — Margin`;
const canonical = `https://marginread.com${Astro.url.pathname}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? `${title} for Margin Read.`} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Open Graph + Twitter cards — same image as the main site;
        the legal pages aren't expected to be shared as primary
        marketing surfaces, but social previews should still resolve. */}
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description ?? `${title} for Margin Read.`} />
    <meta property="og:image" content="https://marginread.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Margin — bilingual webpage translation." />
    <meta property="og:site_name" content="Margin" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description ?? `${title} for Margin Read.`} />
    <meta name="twitter:image" content="https://marginread.com/og.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;1,8..60,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-locale="en">
    <header class="legal-topbar">
      <div class="legal-topbar-inner">
        <a href="/" class="legal-brand">
          <MarginMark />
          <span>Margin</span>
        </a>
        <a href="/" class="legal-back">← Back to marginread.com</a>
      </div>
    </header>

    <main class="legal-wrap">
      <article class="legal-doc">
        <p class="legal-eyebrow">
          <span>Effective</span> <time datetime={effective}>{effective}</time>
        </p>
        <h1 class="legal-title serif">{title}</h1>
        <div class="legal-prose">
          <slot />
        </div>
      </article>
    </main>

    <SiteFooter locale="en" />

    <style>
      .legal-topbar {
        background: var(--cream);
        border-bottom: 1px solid var(--line);
      }
      .legal-topbar-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 14px 32px;
        max-width: 1240px;
        margin: 0 auto;
        gap: 24px;
      }
      .legal-brand {
        display: flex;
        align-items: center;
        gap: 12px;
        font-family: 'Playfair Display', Georgia, serif;
        font-size: 22px;
        letter-spacing: -.005em;
      }
      .legal-back {
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        letter-spacing: .04em;
        color: var(--mute);
      }
      .legal-back:hover { color: var(--ink); }

      .legal-wrap {
        max-width: 720px;
        margin: 0 auto;
        padding: 56px 32px 88px;
      }
      .legal-eyebrow {
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        letter-spacing: .16em;
        text-transform: uppercase;
        color: var(--jam);
        margin: 0 0 18px;
      }
      .legal-eyebrow span { color: var(--mute); margin-right: 10px; }
      .legal-title {
        font-size: clamp(38px, 5vw, 58px);
        line-height: 1.05;
        letter-spacing: -.01em;
        margin: 0 0 40px;
      }

      /* Prose typography — applies to whatever the markdown renders */
      .legal-prose {
        font-family: 'Source Serif 4', Georgia, serif;
        font-size: 17px;
        line-height: 1.7;
        color: var(--ink-soft);
      }
      .legal-prose h2 {
        font-family: 'Playfair Display', Georgia, serif;
        font-weight: 500;
        font-size: 26px;
        line-height: 1.2;
        letter-spacing: -.005em;
        color: var(--ink);
        margin: 52px 0 16px;
      }
      .legal-prose h2:first-child { margin-top: 0; }
      .legal-prose h3 {
        font-family: 'Inter', sans-serif;
        font-weight: 600;
        font-size: 16px;
        letter-spacing: .01em;
        color: var(--ink);
        margin: 32px 0 10px;
      }
      .legal-prose p { margin: 0 0 18px; }
      .legal-prose ul, .legal-prose ol { margin: 0 0 22px; padding-left: 22px; }
      .legal-prose li { margin: 0 0 8px; }
      .legal-prose strong { color: var(--ink); font-weight: 600; }
      .legal-prose a {
        color: var(--jam);
        border-bottom: 1px solid rgba(184, 51, 31, .35);
      }
      .legal-prose a:hover { border-bottom-color: var(--jam); }
      .legal-prose code {
        font-family: 'JetBrains Mono', monospace;
        font-size: .9em;
        background: var(--paper-2);
        padding: 1px 6px;
        border-radius: 3px;
        color: var(--ink);
      }
      .legal-prose pre {
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        line-height: 1.55;
        background: var(--paper);
        border: 1px solid var(--line);
        border-left: 3px solid var(--jam);
        border-radius: 4px;
        padding: 16px 18px;
        margin: 0 0 22px;
        overflow-x: auto;
      }
      .legal-prose pre code {
        background: none;
        padding: 0;
        font-size: inherit;
      }
      .legal-prose blockquote {
        border-left: 3px solid var(--jam);
        margin: 0 0 22px;
        padding: 4px 0 4px 20px;
        color: var(--ink-soft);
        font-style: italic;
      }
      .legal-prose blockquote p:last-child { margin-bottom: 0; }
      .legal-prose hr {
        border: none;
        border-top: 1px solid var(--line);
        margin: 44px 0;
      }
      .legal-prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 0 0 22px;
        font-family: 'Inter', sans-serif;
        font-size: 15px;
      }
      .legal-prose th, .legal-prose td {
        text-align: left;
        padding: 10px 12px;
        border-bottom: 1px solid var(--line);
      }
      .legal-prose th {
        font-weight: 600;
        color: var(--ink);
        border-bottom: 1px solid var(--line-strong);
      }
    </style>
  </body>
</html>
