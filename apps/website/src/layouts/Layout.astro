---
import "../styles/global.css";
import { getAbsoluteLocaleUrl } from "astro:i18n";
import { useTranslations, type Locale } from "../i18n/utils";
import { locales, htmlLang } from "../i18n/ui";

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
}

const { locale, title, description } = Astro.props;
const t = useTranslations(locale);

const pageTitle = title ?? t("html.title");
const pageDescription = description ?? t("html.description");

// `Astro.url.pathname` is the current locale's path (e.g. `/zh-Hant/`).
// Strip the locale prefix so we can rebuild absolute URLs for each peer.
const stripped = Astro.url.pathname.replace(
  new RegExp(`^/(?:${locales.join("|")})(?=/|$)`),
  "",
);
const path = stripped === "" ? "/" : stripped;

const alternates = locales.map((l) => ({
  hreflang: htmlLang[l],
  href: getAbsoluteLocaleUrl(htmlLang[l], path),
}));
const xDefault = getAbsoluteLocaleUrl(htmlLang.en, path);
const canonical = getAbsoluteLocaleUrl(htmlLang[locale], path);
---

<!doctype html>
<html lang={htmlLang[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonical} />
    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;1,8..60,400&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Caveat:wght@500;600&family=Noto+Serif+TC:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-locale={locale}>
    <slot />
    <script>
      import "../scripts/site.ts";
    </script>
  </body>
</html>
