---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="honest" style="border-top: 1px solid var(--line);">
  <p class="eyebrow">
    <span class="num">08</span><span>{t("hon.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("hon.t1")}</span>
    <em>{t("hon.t2")}</em><span>{t("hon.t3")}</span>
  </h2>
  <p class="section-lede">{t("hon.lede")}</p>

  <div class="features" style="background: var(--cream);">
    <div class="feature" style="padding-top: 28px;">
      <div class="num">L.01</div>
      <h3>{t("lim.1t")}</h3>
      <p>{t("lim.1b")}</p>
    </div>
    <div class="feature" style="padding-top: 28px;">
      <div class="num">L.02</div>
      <h3>{t("lim.2t")}</h3>
      <p>{t("lim.2b")}</p>
    </div>
    <div class="feature" style="padding-top: 28px;">
      <div class="num">L.03</div>
      <h3>{t("lim.3t")}</h3>
      <p>{t("lim.3b")}</p>
    </div>
  </div>
</section>
