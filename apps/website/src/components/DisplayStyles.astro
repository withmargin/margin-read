---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="styles">
  <p class="eyebrow">
    <span class="num">05</span><span>{t("dis.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("dis.t1")}</span>
    <em>{t("dis.t2")}</em><span>{t("dis.t3")}</span>
  </h2>
  <p class="section-lede">{t("dis.lede")}</p>

  <div class="styles-compare">
    <div class="style-card">
      <div class="label">{t("dis.a_label")}</div>
      <h4>{t("dis.a_t")}</h4>
      <div class="preview-block">
        <div class="src">{t("dis.src")}</div>
        <div class="tr-integrated">
          <strong class="tr-label-jam">譯</strong>{t("dis.tr")}
        </div>
      </div>
      <p>{t("dis.a_b")}</p>
    </div>
    <div class="style-card">
      <div class="label">{t("dis.b_label")}</div>
      <h4>{t("dis.b_t")}</h4>
      <div class="preview-block">
        <div class="src">{t("dis.src")}</div>
        <div class="tr-highlight">
          <strong class="tr-label-crust">譯</strong>{t("dis.tr")}
        </div>
      </div>
      <p>{t("dis.b_b")}</p>
    </div>
  </div>
</section>
