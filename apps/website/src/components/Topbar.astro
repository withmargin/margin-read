---
import { getRelativeLocaleUrl } from "astro:i18n";
import MarginMark from "./MarginMark.astro";
import { useTranslations, type Locale } from "../i18n/utils";
import { locales, localeLabel, htmlLang } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div class="topbar">
  <div class="topbar-inner">
    <a href={getRelativeLocaleUrl(htmlLang[locale], "/")} class="brand">
      <MarginMark />
      <span>Margin</span>
      <small>{t("topbar.kicker")}</small>
    </a>
    <nav class="links">
      <a href="#demo">{t("nav.demo")}</a>
      <a href="#features">{t("nav.features")}</a>
      <a href="#privacy">{t("nav.privacy")}</a>
      <a href="#providers">{t("nav.providers")}</a>
      <a
        href="https://github.com/linyiru/margin-read/"
        target="_blank"
        rel="noopener">{t("nav.github")}</a>
    </nav>
    <div class="controls">
      <div class="lang-switch" role="tablist" aria-label="Language">
        {
          locales.map((l) => (
            <a
              href={getRelativeLocaleUrl(htmlLang[l], "/")}
              class:list={["lang-link", { on: l === locale }]}
              hreflang={htmlLang[l]}
              aria-current={l === locale ? "true" : "false"}
            >
              {localeLabel[l]}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>
