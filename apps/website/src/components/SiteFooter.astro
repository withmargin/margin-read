---
import MarginMark from "./MarginMark.astro";
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const year = new Date().getFullYear();
---

<footer class="site">
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <MarginMark />
          <span>Margin</span>
        </div>
        <p class="footer-tag">{t("ft.tag")}</p>
      </div>
      <div>
        <h5>{t("ft.h1")}</h5>
        <ul>
          <li><a href="/#demo">{t("ft.demo")}</a></li>
          <li><a href="/#features">{t("ft.features")}</a></li>
          <li><a href="/#privacy">{t("ft.privacy")}</a></li>
          <li><a href="/#styles">{t("ft.styles")}</a></li>
        </ul>
      </div>
      <div>
        <h5>{t("ft.h2")}</h5>
        <ul>
          <li>
            <a
              href="https://github.com/withmargin/margin-read/blob/main/docs/PRD.md"
              target="_blank"
              rel="noopener">PRD</a>
          </li>
          <li>
            <a
              href="https://github.com/withmargin/margin-read/blob/main/docs/PRINCIPLES.md"
              target="_blank"
              rel="noopener">Principles</a>
          </li>
          <li>
            <a
              href="https://github.com/withmargin/margin-read/blob/main/docs/THREAT_MODEL.md"
              target="_blank"
              rel="noopener">Threat Model</a>
          </li>
          <li>
            <a
              href="https://github.com/withmargin/margin-read/blob/main/docs/ROADMAP.md"
              target="_blank"
              rel="noopener">Roadmap</a>
          </li>
        </ul>
      </div>
      <div>
        <h5>{t("ft.h3")}</h5>
        <ul>
          <li>
            <a
              href="https://github.com/withmargin/margin-read/"
              target="_blank"
              rel="noopener">GitHub</a>
          </li>
          <li>
            <a
              href="https://github.com/withmargin/margin-read/issues"
              target="_blank"
              rel="noopener">Issues</a>
          </li>
          <li>
            <a
              href="https://github.com/withmargin/margin-read/blob/main/LICENSE"
              target="_blank"
              rel="noopener">License (MIT)</a>
          </li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© {year} Margin · <span>{t("ft.priv")}</span></span>
      <span class="footer-legal">
        <a href="/privacy">{t("ft.priv_policy")}</a>
        <span class="sep" aria-hidden="true">·</span>
        <a href="/terms">{t("ft.tos")}</a>
      </span>
      <span
        ><a
          href="https://github.com/withmargin/margin-read/"
          target="_blank"
          rel="noopener">github.com/withmargin/margin-read →</a
        ></span
      >
    </div>
  </div>
</footer>
