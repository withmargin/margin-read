---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="features">
  <p class="eyebrow">
    <span class="num">02</span><span>{t("feat.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("feat.t1")}</span>
    <em>{t("feat.t2")}</em>
    <span>{t("feat.t3")}</span>
  </h2>
  <p class="section-lede">{t("feat.lede")}</p>

  <div class="features">
    <div class="feature">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <rect x="3" y="4" width="18" height="3" rx=".5"></rect>
          <rect x="3" y="8.5" width="14" height="3" rx=".5"></rect>
          <line class="pen" x1="6" y1="14" x2="6" y2="21"></line>
          <rect x="8" y="13.5" width="13" height="2.4" rx=".5" class="pen"></rect>
          <rect x="8" y="17.5" width="10" height="2.4" rx=".5" class="pen"></rect>
        </svg>
      </div>
      <div class="num">F.01</div>
      <h3>{t("f1.t")}</h3>
      <p>{t("f1.b")}</p>
    </div>
    <div class="feature">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <path d="M5 4 L19 4 L19 20 L5 20 Z"></path>
          <line x1="8" y1="9" x2="16" y2="9"></line>
          <line x1="8" y1="13" x2="14" y2="13"></line>
          <line x1="8" y1="17" x2="12" y2="17"></line>
          <circle cx="16" cy="17" r="3" class="pen"></circle>
          <line x1="18.2" y1="19.2" x2="20.5" y2="21.5" class="pen"></line>
        </svg>
      </div>
      <div class="num">F.02</div>
      <h3>{t("f2.t")}</h3>
      <p>{t("f2.b")}</p>
    </div>
    <div class="feature">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <path d="M6 6 L18 6 L18 18 L6 18 Z"></path>
          <line x1="9" y1="3" x2="9" y2="6"></line>
          <line x1="15" y1="3" x2="15" y2="6"></line>
          <line x1="9" y1="18" x2="9" y2="21"></line>
          <line x1="15" y1="18" x2="15" y2="21"></line>
          <line x1="3" y1="9" x2="6" y2="9"></line>
          <line x1="3" y1="15" x2="6" y2="15"></line>
          <line x1="18" y1="9" x2="21" y2="9"></line>
          <line x1="18" y1="15" x2="21" y2="15"></line>
          <line x1="10" y1="12" x2="14" y2="12" class="pen"></line>
          <line x1="12" y1="10" x2="12" y2="14" class="pen"></line>
        </svg>
      </div>
      <div class="num">F.03</div>
      <h3>{t("f3.t")}</h3>
      <p>{t("f3.b")}</p>
    </div>
    <div class="feature">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <path d="M8 10 V8 a4 4 0 0 1 8 0 V10"></path>
          <rect x="5" y="10" width="14" height="10" rx="1"></rect>
          <line x1="12" y1="14" x2="12" y2="16.5" class="pen"></line>
        </svg>
      </div>
      <div class="num">F.04</div>
      <h3>{t("f4.t")}</h3>
      <p>{t("f4.b")}</p>
    </div>
    <div class="feature">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <rect x="2.5" y="3.5" width="19" height="17" rx="1.5"></rect>
          <line x1="6" y1="7" x2="18" y2="17" class="pen"></line>
          <line x1="18" y1="7" x2="6" y2="17" class="pen"></line>
        </svg>
      </div>
      <div class="num">F.05</div>
      <h3>{t("f5.t")}</h3>
      <p>{t("f5.b")}</p>
    </div>
    <div class="feature">
      <div class="icon">
        <svg viewBox="0 0 24 24">
          <ellipse cx="12" cy="6" rx="8" ry="2.5"></ellipse>
          <path d="M4 6 V12 a8 2.5 0 0 0 16 0 V6"></path>
          <path d="M4 12 V18 a8 2.5 0 0 0 16 0 V12"></path>
          <line x1="9" y1="18" x2="11" y2="18" class="pen"></line>
        </svg>
      </div>
      <div class="num">F.06</div>
      <h3>{t("f6.t")}</h3>
      <p>{t("f6.b")}</p>
    </div>
  </div>
</section>
