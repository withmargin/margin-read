---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="demo">
  <p class="eyebrow">
    <span class="num">01</span><span>{t("demo.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("demo.t1")}</span> <em>{t("demo.t2")}</em>
  </h2>
  <p class="section-lede">{t("demo.lede")}</p>

  <div
    class="demo-stage"
    id="demoStage"
    data-label-integrated={t("demo.mode_int")}
    data-label-highlight={t("demo.mode_hl")}
    data-label-translate={t("demo.translate")}
    data-label-translated={t("demo.translated")}
  >
    <div class="demo-bar">
      <div class="demo-window">
        <span class="dot" style="background:#e88670"></span>
        <span class="dot" style="background:#e8c170"></span>
        <span class="dot" style="background:#a8c98a"></span>
        <span class="url">arxiv.org/abs/2401.04088</span>
      </div>
      <div class="demo-controls">
        <button id="modeBtn" data-mode="integrated" type="button">
          <span>{t("demo.mode_int")}</span>
        </button>
        <button class="primary" id="translateBtn" type="button">
          <span>{t("demo.translate")}</span>
        </button>
      </div>
    </div>
    <div class="demo-body">
      <div class="demo-article-meta">{t("demo.meta")}</div>
      <h3 class="demo-article-title">{t("demo.title")}</h3>
      <div class="demo-byline">{t("demo.byline")}</div>

      <p class="demo-para first" data-orig>{t("demo.p1")}</p>
      <div class="demo-translation hidden" data-tr>
        <span class="label">譯</span><span>{t("demo.p1_zh")}</span>
      </div>

      <p class="demo-para" data-orig>{t("demo.p2")}</p>
      <div class="demo-translation hidden" data-tr>
        <span class="label">譯</span><span>{t("demo.p2_zh")}</span>
      </div>

      <p class="demo-para" data-orig>{t("demo.p3")}</p>
      <div class="demo-translation hidden" data-tr>
        <span class="label">譯</span><span>{t("demo.p3_zh")}</span>
      </div>

      <p class="demo-para" data-orig>{t("demo.p4")}</p>
      <div class="demo-translation hidden" data-tr>
        <span class="label">譯</span><span>{t("demo.p4_zh")}</span>
      </div>
    </div>
  </div>
</section>
