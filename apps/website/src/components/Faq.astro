---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const items = [
  { num: "Q.01", q: t("faq.q1"), a: t("faq.a1") },
  { num: "Q.02", q: t("faq.q2"), a: t("faq.a2") },
  { num: "Q.03", q: t("faq.q3"), a: t("faq.a3") },
  { num: "Q.04", q: t("faq.q4"), a: t("faq.a4") },
  { num: "Q.05", q: t("faq.q5"), a: t("faq.a5") },
  { num: "Q.06", q: t("faq.q6"), a: t("faq.a6") },
  { num: "Q.07", q: t("faq.q7"), a: t("faq.a7") },
];
---

<section id="faq">
  <p class="eyebrow">
    <span class="num">10</span><span>{t("faq.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("faq.t1")}</span>
    <em>{t("faq.t2")}</em><span>{t("faq.t3")}</span>
  </h2>
  <p class="section-lede">{t("faq.lede")}</p>

  <div class="faq-list">
    {
      items.map((item, i) => (
        <details class="faq" open={i === 0}>
          <summary>
            <span class="q-num">{item.num}</span>
            <span>{item.q}</span>
            <span class="q-marker">+</span>
          </summary>
          <div class="answer">{item.a}</div>
        </details>
      ))
    }
  </div>
</section>
