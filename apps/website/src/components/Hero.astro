---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

// Chrome Web Store listing. The extension id is also used by the live
// version fetch in site.ts (shields.io JSON endpoint for the same id).
const STORE_URL =
  "https://chromewebstore.google.com/detail/margin-read/clgdnabgpfiffmfdboefecbhggbepjde";
---

<section class="hero" id="top">
  <p class="eyebrow">{t("hero.eyebrow")}</p>
  <div class="hero-grid">
    <div>
      <h1 class="serif">
        <span>{t("hero.t1")}</span><span>{t("hero.t1b")}</span>
        <em>{t("hero.t2")}</em><span>{t("hero.t3")}</span>
      </h1>
      <p class="pitch">
        <strong>{t("hero.p1")}</strong>
        <span>{t("hero.p2")}</span>
      </p>
      <div class="cta-row">
        <a
          class="cta primary"
          href={STORE_URL}
          target="_blank"
          rel="noopener">
          <span>{t("hero.cta1")}</span>
          <span class="cta-meta mono">{t("hero.cta1m")}</span>
        </a>
        <button class="cta" id="openWaitlistBtn" type="button">
          <span>{t("hero.cta2")}</span>
          <span class="cta-meta mono">{t("hero.cta2m")}</span>
        </button>
      </div>
      <a
        class="cws-ver hidden"
        id="cwsVer"
        href={STORE_URL}
        target="_blank"
        rel="noopener">
        <span class="dot">●</span>
        <span>{t("hero.ver_label")}</span>
        <span class="mono" id="cwsVerNum"></span>
      </a>
      <div class="follow hidden" id="follow-panel">
        <p class="follow-lede">{t("hero.follow_lede")}</p>
        <div class="follow-grid">
          <a
            class="follow-card"
            href="https://github.com/withmargin/margin-read"
            target="_blank"
            rel="noopener">
            <span class="follow-card-tag mono">GH</span>
            <span class="follow-card-body">
              <strong>{t("hero.follow_gh_t")}</strong>
              <span>{t("hero.follow_gh_d")}</span>
            </span>
          </a>
          <a
            class="follow-card"
            href="https://github.com/withmargin/margin-read/releases.atom"
            target="_blank"
            rel="noopener">
            <span class="follow-card-tag mono">RSS</span>
            <span class="follow-card-body">
              <strong>{t("hero.follow_rss_t")}</strong>
              <span>{t("hero.follow_rss_d")}</span>
            </span>
          </a>
        </div>
      </div>
      <p class="signup-note">
        <span class="dot">●</span>
        <span>{t("hero.note")}</span>
      </p>
    </div>
    <div>
      <div class="hero-page" aria-hidden="true">
        <div class="hp-corner mono">
          <span>{t("hero.fig")}</span><span>{t("hero.fig_label")}</span>
        </div>
        <div class="hp-spine"></div>
        <div class="hp-meta mono">{t("hero.hp_meta")}</div>
        <h4 class="hp-title serif">{t("hero.hp_title")}</h4>
        <div class="hp-byline mono">{t("hero.hp_byline")}</div>
        <p class="hp-para hp-en">{t("hero.hp_p1")}</p>
        <p class="hp-para hp-zh">{t("hero.hp_p1z")}</p>
        <p class="hp-para hp-en">{t("hero.hp_p2")}</p>
        <p class="hp-para hp-zh">{t("hero.hp_p2z")}</p>
        <div class="hp-cap mono">
          <span>{t("hero.hp_cap1")}</span><span>{t("hero.hp_cap2")}</span>
        </div>
      </div>
    </div>
  </div>

  <div class="marquee">
    <div class="marquee-track" id="marquee">
      <span><span class="star">✦</span> Privacy-first</span>
      <span><span class="star">✦</span> 隱私優先</span>
      <span><span class="star">✦</span> Bring Your Own Key</span>
      <span><span class="star">✦</span> 自帶 API Key</span>
      <span><span class="star">✦</span> No telemetry</span>
      <span><span class="star">✦</span> 不追蹤</span>
      <span><span class="star">✦</span> Open Source · MIT</span>
      <span><span class="star">✦</span> 開源 MIT</span>
      <span><span class="star">✦</span> Chrome MV3</span>
      <span><span class="star">✦</span> OpenAI · Claude · Gemini</span>
    </div>
  </div>
</section>
