---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="xopt">
  <p class="eyebrow">
    <span class="num">06</span><span>{t("x.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("x.t1")}</span>
    <em>{t("x.t2")}</em><span>{t("x.t3")}</span>
  </h2>
  <p class="section-lede">{t("x.lede")}</p>

  <div class="xopt-grid">
    <div>
      <div class="x-card">
        <div class="x-head">
          <div class="x-avatar"></div>
          <div>
            <div>
              <span class="x-name">{t("x.name")}</span><span class="x-handle"
                >{t("x.handle")}</span
              >
            </div>
            <div class="x-handle">{t("x.time")}</div>
          </div>
        </div>
        <div class="x-text">{t("x.tweet")}</div>
        <div class="x-translation">
          <span class="label">譯</span><span>{t("x.tweet_zh")}</span>
        </div>
        <div class="x-skip">
          <span class="strike">@mariyamada</span> ·
          <span class="strike">142 ❤</span> ·
          <span class="strike">38 ↻</span> ·
          <span>{t("x.skip")}</span>
        </div>
      </div>
    </div>
    <div>
      <ul class="xopt-list">
        <li><span class="check">✓</span><span>{t("x.l1")}</span></li>
        <li><span class="check">✓</span><span>{t("x.l2")}</span></li>
        <li><span class="check">✓</span><span>{t("x.l3")}</span></li>
        <li><span class="check">✓</span><span>{t("x.l4")}</span></li>
        <li><span class="check">✓</span><span>{t("x.l5")}</span></li>
        <li><span class="check">✓</span><span>{t("x.l6")}</span></li>
      </ul>
    </div>
  </div>
</section>
