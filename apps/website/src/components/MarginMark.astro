---
// M.12 Paragraph Pair logo — black ¶ over indented red ¶
// Inherits palette from CSS custom props on `.toast-mark` so the
// footer (dark) override works without prop changes.
---

<span class="toast-mark" aria-hidden="true">
  <span class="para k"><span class="ln"></span><span class="ln s"></span></span>
  <span class="para p"><span class="ln"></span><span class="ln s"></span></span>
</span>
