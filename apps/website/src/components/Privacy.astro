---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="privacy">
  <p class="eyebrow">
    <span class="num">04</span><span>{t("priv.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("priv.t1")}</span>
    <em>{t("priv.t2")}</em><span>{t("priv.t3")}</span>
  </h2>
  <p class="section-lede">{t("priv.lede")}</p>

  <div class="privacy-grid">
    <ul class="privacy-points">
      <li>
        <div class="num">P.01</div>
        <div>
          <h4>{t("priv.p1t")}</h4>
          <p>{t("priv.p1b")}</p>
        </div>
      </li>
      <li>
        <div class="num">P.02</div>
        <div>
          <h4>{t("priv.p2t")}</h4>
          <p>{t("priv.p2b")}</p>
        </div>
      </li>
      <li>
        <div class="num">P.03</div>
        <div>
          <h4>{t("priv.p3t")}</h4>
          <p>{t("priv.p3b")}</p>
        </div>
      </li>
      <li>
        <div class="num">P.04</div>
        <div>
          <h4>{t("priv.p4t")}</h4>
          <p>{t("priv.p4b")}</p>
        </div>
      </li>
      <li>
        <div class="num">P.05</div>
        <div>
          <h4>{t("priv.p5t")}</h4>
          <p>{t("priv.p5b")}</p>
        </div>
      </li>
    </ul>

    <aside class="privacy-flow">
      <div class="flow-title">{t("flow.title")}</div>
      <div class="flow-row you">
        <div class="blob">U</div>
        <div>
          <div>{t("flow.you")}</div>
          <em>{t("flow.you_sub")}</em>
        </div>
      </div>
      <div class="flow-arrow"></div>
      <div class="flow-row margin">
        <div class="blob">M</div>
        <div>
          <div>{t("flow.margin")}</div>
          <em>{t("flow.detect_sub")}</em>
        </div>
      </div>
      <div class="flow-arrow"></div>
      <div class="flow-row prov">
        <div class="blob">AI</div>
        <div>
          <div>{t("flow.prov")}</div>
          <em>{t("flow.prov_sub")}</em>
        </div>
      </div>
      <div class="flow-foot">
        ✦ <span>{t("flow.foot")}</span>
      </div>
    </aside>
  </div>
</section>
