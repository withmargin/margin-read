---
import { useTranslations, type Locale } from "../i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="pricing">
  <p class="eyebrow">
    <span class="num">09</span><span>{t("price.eye")}</span>
  </p>
  <h2 class="serif">
    <span>{t("price.t1")}</span>
    <em>{t("price.t2")}</em><span>{t("price.t3")}</span>
  </h2>
  <p class="section-lede">{t("price.lede")}</p>

  <div class="pricing-grid">
    <div class="calc">
      <h4>{t("price.calc")}</h4>

      <div class="calc-row">
        <span>{t("price.pages")}</span>
        <span class="v" id="calcPagesV">10</span>
      </div>
      <input type="range" id="calcPages" min="1" max="100" value="10" step="1" />

      <div class="calc-row">
        <span>{t("price.words")}</span>
        <span class="v" id="calcWordsV">1,200</span>
      </div>
      <input
        type="range"
        id="calcWords"
        min="200"
        max="5000"
        value="1200"
        step="100"
      />

      <div class="calc-row" style="margin-bottom:10px">
        <span>{t("price.model")}</span>
        <span class="v" id="calcModelV">GPT-4o mini</span>
      </div>
      <div class="pick" id="calcModelPick">
        <button data-rate="0.15" class="on" type="button">GPT-4o mini</button>
        <button data-rate="2.50" type="button">GPT-4o</button>
        <button data-rate="0.80" type="button">Haiku 3.5</button>
        <button data-rate="3.00" type="button">Sonnet 3.7</button>
        <button data-rate="0.10" type="button">Gemini Flash</button>
      </div>

      <div class="calc-out">
        <div>
          <div class="v"><em>$</em><span id="calcDay">0.07</span></div>
          <div class="l">{t("price.per_day")}</div>
        </div>
        <div>
          <div class="v"><em>$</em><span id="calcMonth">2.16</span></div>
          <div class="l">{t("price.per_month")}</div>
        </div>
      </div>
    </div>

    <ul class="price-notes">
      <li><div class="n">$.01</div><div>{t("price.n1")}</div></li>
      <li><div class="n">$.00</div><div>{t("price.n2")}</div></li>
      <li><div class="n">B Y O</div><div>{t("price.n3")}</div></li>
      <li><div class="n">FREE</div><div>{t("price.n4")}</div></li>
    </ul>
  </div>
</section>
