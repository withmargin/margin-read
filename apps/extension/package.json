{
  "name": "@margin/extension",
  "version": "0.1.0",
  "description": "Privacy-first translation and notes, placed where reading happens.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm clean && rolldown -c && node scripts/copy-assets.mjs",
    "check": "tsc --noEmit",
    "check:extension": "node scripts/check-extension.mjs",
    "clean": "node scripts/clean.mjs",
    "lint": "eslint src vitest.config.ts rolldown.config.ts",
    "package": "pnpm build && node scripts/package-extension.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  }
}
