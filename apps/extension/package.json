{
  "name": "@margin/extension",
  "version": "0.3.5",
  "description": "Privacy-first bilingual web translation that keeps the original text in place so you never lose context.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "tsc --noEmit",
    "check:extension": "node scripts/check-extension.mjs",
    "check:release-readiness": "node scripts/check-release-readiness.mjs",
    "check:release-version": "node scripts/check-release-version.mjs",
    "clean": "node scripts/clean.mjs",
    "lint": "eslint src vitest.config.ts vite.config.ts",
    "fixture:capture": "node scripts/capture-fixture.mjs",
    "package": "pnpm build && node scripts/package-extension.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@crxjs/vite-plugin": "^2.4.0",
    "@google/genai": "^2.1.0",
    "openai": "^6.37.0",
    "vite": "^8.0.16"
  }
}
