{
  "name": "toast",
  "version": "0.1.0",
  "description": "A privacy-first, open-source bilingual webpage translation project.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "build": "pnpm --filter @toast/extension build",
    "check": "pnpm --filter @toast/extension check",
    "check:extension": "pnpm --filter @toast/extension check:extension",
    "clean": "pnpm --filter @toast/extension clean",
    "lint": "pnpm --filter @toast/extension lint",
    "test": "pnpm --filter @toast/extension test",
    "test:watch": "pnpm --filter @toast/extension test:watch"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.0.268",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "rolldown": "^1.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
